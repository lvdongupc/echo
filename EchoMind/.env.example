# EchoMind 环境变量配置示例
# 复制此文件为 .env 并填写实际值

# ── 应用 ──────────────────────────────────────────────────────────────────────
APP_NAME=EchoMind
APP_ENV=production
LOG_LEVEL=INFO

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Anthropic Claude ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# 可选：覆盖为兼容 Anthropic 协议的第三方 API（如 DeepSeek）
# ANTHROPIC_BASE_URL=https://api.deepseek.com/anthropic

# 可选：覆盖模型名称（默认 claude-3-5-sonnet-20241022）
# 使用 DeepSeek 时设为 deepseek-chat
# ANTHROPIC_MODEL=deepseek-chat

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=echomind123

# ── ChromaDB ──────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_PERSIST_DIRECTORY=./data/chroma

# ── 监控 ──────────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9091
MONITOR_INTERVAL=10
ANOMALY_DETECTION_THRESHOLD=2.5

# Monitor 告警阈值（默认已适配远程 LLM；5–6s Agent 延迟通常不告警）
# MONITOR_AGENT_SUCCESS_RATE_THRESHOLD=0.80
# MONITOR_AGENT_AVG_MS_THRESHOLD=8000
# MONITOR_PENALTY_SUCCESS_RATE=0.85
# MONITOR_PENALTY_AVG_MS=7000

# Demo：technical_2 (legacy) 约 35% 模拟失败，用于演示 Monitor 路由降权闭环
# DEMO_WEAK_TECHNICAL=1

# ── 评测 ──────────────────────────────────────────────────────────────────────
EVAL_BASELINE_PATH=./evaluation/baselines/baseline.json

# 运行评测 CLI（需配置 ANTHROPIC_API_KEY）:
#   python -m evaluation.run_eval --intent-only    # 仅意图（约 92 条，~3 分钟）
#   python -m evaluation.run_eval                    # 完整评测（含 LLM Judge 对话质量）
#   python -m pytest tests -q                        # 单元测试（34 项，无需 API）

# ── 安全 ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_this_in_production
JWT_SECRET_KEY=change_this_in_production

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── 功能开关 ──────────────────────────────────────────────────────────────────
ENABLE_SWAGGER_UI=true
ENABLE_MONITORING=true
ENABLE_EVALUATION=true

# MCP 工具调用模式：
#   legacy — API 层预检索知识库后注入 context（默认，与改前行为接近）
#   agent  — Agent 通过 MCP 自主决定何时调用 knowledge_search
TOOL_MODE=legacy
